# Choose one: auto, glm4, deepseek, gemini-lite, gemini, grok, openrouter, cerebras, or antigravity
# auto routes daily lookups to GLM, bulk work to DeepSeek, and Google-quality fallback to Gemini Flash-Lite.
AI_PROVIDER=auto

# Antigravity local proxy (OpenAI-compatible)
ANTIGRAVITY_BASE_URL=http://127.0.0.1:8045/v1
ANTIGRAVITY_API_KEY=your_antigravity_api_key_here
ANTIGRAVITY_MODEL=gemini-3-flash

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_LITE_MODEL=gemini-2.5-flash-lite

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Grok / xAI
XAI_API_KEY=your_xai_api_key_here
XAI_MODEL=your_xai_model_here

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=your_openrouter_model_here

# Cerebras
CEREBRAS_API_KEY=your_cerebras_api_key_here
CEREBRAS_MODEL=llama3.1-8b

# Z.ai / GLM
GLM4_API_KEY=your_zai_api_key_here
GLM4_MODEL=glm-4.7-flash
# Optional. Defaults try Z.ai first, then BigModel.
# GLM4_BASE_URL=https://api.z.ai/api/paas/v4

# Backend
PORT=3001

# Google Cloud Text-to-Speech
# Keep this server-side. The website and extension call /api/tts instead of Google directly.
GOOGLE_TTS_KEY=your_google_cloud_tts_api_key_here
GOOGLE_TTS_VOICE=en-US-Neural2-J
GOOGLE_TTS_LANGUAGE=en-US
GOOGLE_TTS_SPEAKING_RATE=0.9

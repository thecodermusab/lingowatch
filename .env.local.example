# Choose one: auto, glm4, deepseek, gemini-lite, gemini, grok, openrouter, cerebras, or antigravity
# auto routes daily lookups to GLM, bulk work to DeepSeek, and Google-quality fallback to Gemini Flash-Lite.
AI_PROVIDER=auto

# Antigravity local proxy (OpenAI-compatible)
ANTIGRAVITY_BASE_URL=http://127.0.0.1:8045/v1
ANTIGRAVITY_API_KEY=your_antigravity_api_key_here
ANTIGRAVITY_MODEL=gemini-3-flash

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_LITE_MODEL=gemini-2.5-flash-lite

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Grok / xAI
XAI_API_KEY=your_xai_api_key_here
XAI_MODEL=your_xai_model_here

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=your_openrouter_model_here

# Cerebras
CEREBRAS_API_KEY=your_cerebras_api_key_here
CEREBRAS_MODEL=llama3.1-8b

# Z.ai / GLM
GLM4_API_KEY=your_zai_api_key_here
GLM4_MODEL=glm-4.7-flash
# Optional. Defaults try Z.ai first, then BigModel.
# GLM4_BASE_URL=https://api.z.ai/api/paas/v4

# Backend
PORT=3001

# Google Sign-In
# Create this in Google Cloud Console > APIs & Services > Credentials > OAuth client ID.
# Use the same client ID for both values so the browser can request an ID token and
# the backend can verify that token before writing the login to Neon.
VITE_GOOGLE_CLIENT_ID=your_google_oauth_web_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your_google_oauth_web_client_id.apps.googleusercontent.com

# Google Cloud service account JSON for cloud deploys.
# Paste the FULL service-account JSON as a single-line string. The server prefers
# this over ./server/gcp-tts-key.json when set, so production never needs the file
# checked into the repo or uploaded to the platform's filesystem.
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Google Cloud Text-to-Speech
# Keep this server-side. The website and extension call /api/tts instead of Google directly.
GOOGLE_TTS_KEY=your_google_cloud_tts_api_key_here
GOOGLE_TTS_VOICE=en-US-Neural2-J
GOOGLE_TTS_LANGUAGE=en-US
GOOGLE_TTS_SPEAKING_RATE=0.9
# Optional monthly character caps. Google is used first, then AWS Polly after this cap.
# Leave unset/0 for no app-level cap.
GOOGLE_TTS_MONTHLY_CHAR_CAP=0

# AWS Polly fallback
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=us-east-1
AWS_POLLY_MONTHLY_CHAR_CAP=0

# Neon stores TTS cache metadata and monthly usage counters.
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# DigitalOcean Spaces stores generated MP3 files.
DO_SPACES_ENDPOINT=https://ams3.digitaloceanspaces.com
DO_SPACES_REGION=ams3
DO_SPACES_BUCKET=lingowatch
DO_SPACES_PUBLIC_BASE_URL=https://lingowatch.ams3.digitaloceanspaces.com
DO_SPACES_ACCESS_KEY_ID=your_spaces_key_here
DO_SPACES_SECRET_ACCESS_KEY=your_spaces_secret_here

# App base URL used in links inside emails.
APP_BASE_URL=http://localhost:8080

# Frontend → API origin used by the website to mint extension session tokens
# and tell the extension where to send authed requests. Leave unset locally to
# use window.location.origin. In production set:
#   VITE_API_BASE_URL=https://api.maahir03.me
#   VITE_APP_BASE_URL=https://maahir03.me
VITE_API_BASE_URL=
VITE_APP_BASE_URL=

# Comma-separated extra origins to allow through CORS (rarely needed).
EXTRA_CORS_ORIGINS=

# Resend email delivery
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM="LingoWatch <hello@yourdomain.com>"
EMAIL_REPLY_TO=support@yourdomain.com
EMAIL_FROM_AUTH="LingoWatch Auth <auth@yourdomain.com>"
EMAIL_FROM_UPDATES="LingoWatch Updates <updates@yourdomain.com>"

# Protects the announcement send endpoint.
ADMIN_ANNOUNCEMENT_KEY=replace_with_a_long_random_secret


RESEND_API_KEY=re_xxxxx
EMAIL_FROM="LingoWatch <hello@finalproject.app>"
EMAIL_FROM_AUTH="LingoWatch Auth <auth@finalproject.app>"
EMAIL_FROM_UPDATES="LingoWatch Updates <updates@finalproject.app>"
EMAIL_REPLY_TO="hello@finalproject.app"
APP_BASE_URL=http://localhost:8080
ADMIN_ANNOUNCEMENT_KEY=lw_9f2c1d4b8e6a7c3f5d1a0b4e9f7c2a6d

{
  "manifest_version": 3,
  "name": "LingoWatch",
  "version": "1.0.9",
  "description": "Learn English from any video with Somali translations",
  "permissions": ["storage", "activeTab", "webRequest", "contextMenus", "scripting", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": ["config.global.js", "app-bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.youtube.com/watch*"],
      "js": ["config.global.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.youtube.com/watch*"],
      "js": ["config.global.js", "subtitle.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon128.png"
  },
  "icons": {
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["data/frequency.json", "icons/icon128.png", "yt-bridge.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
